# Copy to .env and fill in only what you need.
# Never commit .env. Never paste real keys here.
# Full reference: providers/env_vars.md

# --- Default provider for utilities/llm_provider.py ---
LLM_PROVIDER=openai             # openai | anthropic | google | groq | ollama | ...

# =============================================================
# Frontier APIs
# =============================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# =============================================================
# Enterprise clouds
# =============================================================
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
# (Bedrock uses standard AWS auth)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# =============================================================
# Fast inference
# =============================================================
GROQ_API_KEY=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=

# =============================================================
# Marketplaces
# =============================================================
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
DEEPINFRA_API_KEY=

# =============================================================
# Specialty providers
# =============================================================
MISTRAL_API_KEY=
COHERE_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
HF_TOKEN=
REPLICATE_API_TOKEN=
NVIDIA_API_KEY=
MINIMAX_API_KEY=

# =============================================================
# Local runtimes (defaults shown — uncomment to override)
# =============================================================
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# VLLM_BASE_URL=http://localhost:8000/v1
# LLAMACPP_BASE_URL=http://localhost:8080/v1
# Generic OpenAI-compatible (TGI, custom proxy, etc.):
# LOCAL_OPENAI_COMPATIBLE_BASE_URL=
# LOCAL_OPENAI_COMPATIBLE_API_KEY=

# =============================================================
# Router overrides (comma-separated provider chains)
# =============================================================
# ROUTER_DEFAULT=openai,anthropic,openrouter
# ROUTER_CHEAP=groq,deepseek,together,openrouter
# ROUTER_FAST=groq,cerebras,fireworks
# ROUTER_REASONING=anthropic,openai,google,deepseek
# ROUTER_LONG_CONTEXT=google,anthropic,minimax,openai
# ROUTER_VISION=openai,google,anthropic,xai
# ROUTER_LOCAL=ollama,lmstudio,vllm,llamacpp
# ROUTER_RESEARCH=perplexity,openai,anthropic

# =============================================================
# Optional: search / retrieval tools used in research examples
# =============================================================
TAVILY_API_KEY=
SERPAPI_API_KEY=
FIRECRAWL_API_KEY=

# =============================================================
# Optional: MCP integrations (per-server scopes vary)
# =============================================================
GITHUB_TOKEN=
NOTION_API_KEY=
SLACK_BOT_TOKEN=

# =============================================================
# Optional: observability / evals
# =============================================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
PHOENIX_API_KEY=
LANGSMITH_API_KEY=

# =============================================================
# Optional: vector stores
# =============================================================
CHROMA_HOST=
PGVECTOR_DSN=
WEAVIATE_URL=
WEAVIATE_API_KEY=
